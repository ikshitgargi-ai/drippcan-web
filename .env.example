# Dripp Tracker web — environment
#
# NEXT_PUBLIC_API_BASE
#   Empty (recommended for local dev): same-origin proxy — next.config.ts
#   rewrites /api/* and /healthz to http://localhost:5070.
#   Production (Vercel): set to the Render backend explicitly:
#     NEXT_PUBLIC_API_BASE=https://drippcan-tracker.onrender.com
NEXT_PUBLIC_API_BASE=

# Optional: API key header sent as X-API-Key on every request (if backend enforces it)
# NEXT_PUBLIC_API_KEY=
